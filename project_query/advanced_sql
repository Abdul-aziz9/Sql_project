-- finindg the job postings in the first quarter of the year that have a salary above $70,000 and the skills mentioned in those job postings

SELECT
    jpf.job_id,
    jpf.job_title_short,
    jpf.company_id,
    jpf.job_location,
    sd.skills,
    sd.type AS skill_type
FROM job_postings_fact AS jpf
LEFT JOIN skills_job_dim AS sjd
    ON jpf.job_id = sjd.job_id
LEFT JOIN skills_dim AS sd
    ON sjd.skill_id = sd.skill_id
WHERE
    EXTRACT(MONTH FROM jpf.job_posted_date) IN (1, 2, 3)
    AND jpf.salary_year_avg > 70000;

-- Use a CTE and UNION to find the job postings in the first quarter of the year that have a salary above $70,000 and the skills mentioned in those job postings

WITH q1_jobs AS (
    SELECT *
    FROM january_jobs
    WHERE salary_year_avg > 70000

    UNION ALL

    SELECT *
    FROM february_jobs
    WHERE salary_year_avg > 70000

    UNION ALL

    SELECT *
    FROM march_jobs
    WHERE salary_year_avg > 70000
)

SELECT
    q1.job_id,
    q1.job_title_short,
    q1.company_id,
    q1.job_location,
    sd.skills,
    sd.type AS skill_type
FROM q1_jobs AS q1
JOIN skills_job_dim AS sjd
    ON q1.job_id = sjd.job_id
JOIN skills_dim AS sd
    ON sjd.skill_id = sd.skill_id

UNION ALL

SELECT
    q1.job_id,
    q1.job_title_short,
    q1.company_id,
    q1.job_location,
    NULL AS skills,
    NULL AS skill_type
FROM q1_jobs AS q1
WHERE NOT EXISTS (
    SELECT 1
    FROM skills_job_dim AS sjd
    WHERE sjd.job_id = q1.job_id
);


--use subquery and union to find data analyst job postings in the first quarter of the year that have a salary above $70,000 
SELECT 
    job_title_short,
    job_location,
    job_posted_date::DATE,
    salary_year_avg

FROM (SELECT *
    FROM january_jobs
    

    UNION ALL

    SELECT *
    FROM february_jobs
    WHERE salary_year_avg > 70000

    UNION ALL

    SELECT *
    FROM march_jobs) AS q1_jp 
WHERE salary_year_avg > 70000 AND
    job_title_short = 'Data Analyst'
ORDER BY salary_year_avg DESC;